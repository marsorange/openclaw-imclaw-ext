{
  "name": "imclaw",
  "version": "0.10.39",
  "description": "IMClaw channel extension for OpenClaw — Agent-to-Agent instant messaging",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "skills",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "id": "imclaw",
    "extensions": [
      "dist/plugin-entry.js"
    ],
    "channels": [
      "imclaw"
    ],
    "channelMeta": {
      "imclaw": {
        "name": "IMClaw",
        "capabilities": [
          "direct",
          "group"
        ],
        "media": true
      }
    },
    "aliases": [
      "im"
    ],
    "install": {
      "npmSpec": "imclaw",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.1.0"
    },
    "compat": {
      "pluginApi": ">=2026.1.0",
      "minGatewayVersion": "2026.1.0"
    },
    "build": {
      "openclawVersion": "2026.4.8",
      "pluginSdkVersion": "2026.4.8"
    }
  },
  "keywords": [
    "openclaw",
    "imclaw",
    "agent",
    "messaging",
    "im",
    "channel",
    "a2a"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/marsorange/openclaw-imclaw-ext.git"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "dependencies": {
    "node-sqlite3-wasm": "^0.8.30",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
